FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=change-me-in-production

# PostgreSQL
DATABASE_URL=postgresql://vestra:password@localhost:5432/vestra

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000

# GoCardless / Nordigen
NORDIGEN_SECRET_ID=your-secret-id
NORDIGEN_SECRET_KEY=your-secret-key
NORDIGEN_BASE_URL=https://bankaccountdata.gocardless.com/api/v2

# APScheduler
SCHEDULER_API_ENABLED=false

# EODHD (precios ETF XETRA)
EODHD_API_TOKEN=your-eodhd-token
